+  set -a
+  # shellcheck disable=SC1091
+  source "$REPO_ROOT/integrations/openclaw/subagents.env"
+  set +a
+fi
+if [[ -f "$REPO_ROOT/openclaw/.env" ]]; then
+  set -a
+  # shellcheck disable=SC1091
+  source "$REPO_ROOT/openclaw/.env"
+  set +a
+fi
+
+TO="${SLACK_ALERT_USER_ID:-}"
