@@ -0,0 +1,565 @@
+import fs from "node:fs";
+import path from "node:path";
+import { execSync } from "node:child_process";
+
+export const VALID_AGENTS = new Set([
+  "main",
+  "mor-pnl",
+  "mor-smart-router",
+  "mor-liquidity",
+  "mor-dd-risk",
+  "mor-market-mode",
+  "mor-capital-ladder",
