+
+REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
+export OPENCLAW_CONFIG_PATH="${OPENCLAW_CONFIG_PATH:-$REPO_ROOT/integrations/openclaw/openclaw.json}"
