# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# vite
/dist
/.next/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# OpenClaw submodule (source); local install artifacts ignored
/openclaw/node_modules/
/openclaw/dist/
/openclaw/.artifacts/

# MOR OpenClaw integration runtime state
/integrations/openclaw/state/
/integrations/openclaw/openclaw.json
/integrations/openclaw/openclaw.json.bak*
/integrations/openclaw/openclaw.json.last-good
/integrations/openclaw/subagents.env
/integrations/openclaw/workspaces/**/openclaw-workspace-state.json
/integrations/openclaw/workspaces/**/tmp/
/integrations/openclaw/workspaces/**/*-context-*.json
