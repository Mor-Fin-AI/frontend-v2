# Frontend (Vite) — set these in Vercel Project → Environment Variables
VITE_API_URL=https://YOUR-API-HOST/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_WALLETCONNECT_PROJECT_ID=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_ARBITRUM_RPC_URL=
VITE_GOOGLE_MAPS_API_KEY=
VITE_OPENCLAW_DASHBOARD_URL=

# API (Express) — set these on Railway / Render / Docker host
NODE_ENV=production
# Platforms often inject PORT; SERVER_PORT is the local default
SERVER_PORT=3001
# Comma-separated allowed browser origins (Vercel production + previews + local)
CLIENT_ORIGIN=https://YOUR-VERCEL-APP.vercel.app,http://localhost:5173
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PUBLIC_MONTHLY=
STRIPE_PRICE_PUBLIC_ANNUAL=
STRIPE_PRICE_PRIVATE_MONTHLY=
STRIPE_PRICE_PRIVATE_ANNUAL=
