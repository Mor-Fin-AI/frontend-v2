# Frontend Vercel project (repo root) — baked in at BUILD time; redeploy after changes
VITE_API_URL=https://YOUR-API-HOST.vercel.app/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_WALLETCONNECT_PROJECT_ID=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_ARBITRUM_RPC_URL=
VITE_GOOGLE_MAPS_API_KEY=
VITE_OPENCLAW_DASHBOARD_URL=

# API Vercel project (Root Directory: apps/api) — runtime; redeploy after changes
NODE_ENV=production
SERVER_PORT=3001
CLIENT_ORIGIN=https://YOUR-FRONTEND.vercel.app,http://localhost:5173
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PUBLIC_MONTHLY=
STRIPE_PRICE_PUBLIC_ANNUAL=
STRIPE_PRICE_PRIVATE_MONTHLY=
STRIPE_PRICE_PRIVATE_ANNUAL=

# Academy mentors (OpenClaw Hermes + Claude)
# Other apps only need: API URL + MOR_MENTOR_API_KEY to talk with agents.
MOR_MENTOR_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional — only if you host a public OpenClaw gateway (NOT required for mentor chat)
# OPENCLAW_GATEWAY_URL=https://your-openclaw-host
# OPENCLAW_DASHBOARD_URL=https://your-openclaw-host/
