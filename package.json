    "@fluentui/react-datepicker-compat": "^0.6.32",
    "@fluentui/react-icons": "^2.0.330",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/three": "^0.184.1",
    "@web3icons/core": "^4.0.51",
    "@web3icons/react": "^4.1.17",
    "clsx": "^2.1.1",
