{
  "name": "user-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "openclaw:setup": "node scripts/setup-openclaw.mjs",
    "openclaw:gateway": "node scripts/run-openclaw-gateway.mjs",
    "openclaw:alerts:install": "bash scripts/install-slack-alerts.sh",
    "openclaw:cron:install": "node scripts/install-mor-cron-jobs.mjs",
    "openclaw:test-identities": "bash scripts/test-slack-agent-identities.sh",
    "openclaw:deliver": "node scripts/deliver-slack-agent.mjs",
    "openclaw:flashloan:scan": "node scripts/deliver-slack-flashloan-opportunities.mjs",
    "openclaw:flashloan:watch": "node scripts/watch-flashloan-opportunities.mjs",
    "openclaw:roundtable": "node scripts/deliver-slack-roundtable.mjs",
    "openclaw:collab": "node scripts/deliver-slack-collab.mjs",
    "openclaw:github:agents": "node scripts/deliver-slack-github-workflow.mjs --workflow mor-agents",
    "openclaw:github:audit": "node scripts/deliver-slack-github-workflow.mjs --workflow mor-audit",
    "openclaw:github:suggestion": "node scripts/deliver-slack-github-workflow.mjs --workflow mor-suggestion",
    "openclaw:github:codefix": "node scripts/deliver-slack-github-workflow.mjs --workflow mor-codefix",
    "openclaw:slash": "node scripts/mor-slack-slash.mjs",
    "openclaw:slash:diagnose": "node scripts/diagnose-mor-slack.mjs",
    "dev:full": "concurrently -n mor,openclaw \"npm run dev\" \"npm run openclaw:gateway\"",
    "build": "tsc --noEmit && vite build",
    "vercel-build": "node scripts/vercel-build.mjs",
    "vercel:local": "npm run vercel-build && npx --yes serve public -l 4173",
    "preview:web": "npm run vercel-build && npx --yes serve public -l 4173",
    "typecheck": "tsc --noEmit",
    "build:server": "tsc -p server/tsconfig.json",
    "start:server": "node server/dist/index.js",
    "start": "node server/dist/index.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "seed:user": "tsx scripts/seed-user.ts",
    "contracts:sync": "cp \"dsa contracts copy/deployments/latest.json\" src/lib/contracts/deployments.arbitrum.json",
    "ngrok": "ngrok http 5173",
    "github:tunnel": "node scripts/github-webhook-tunnel.mjs",
    "github:tunnel:smee": "node scripts/github-webhook-smee.mjs"
  },
  "dependencies": {
    "@fluentui-contrib/react-chat": "^0.2.2",
    "@fluentui/react-calendar-compat": "^0.4.2",
    "@fluentui/react-charts": "^9.3.19",
    "@fluentui/react-components": "^9.74.1",
    "@fluentui/react-datepicker-compat": "^0.6.32",
    "@fluentui/react-icons": "^2.0.330",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/three": "^0.184.1",
    "@web3icons/core": "^4.0.51",
    "@web3icons/react": "^4.1.17",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ethereum-blockies-base64": "^1.0.2",
    "express": "^5.2.1",
    "framer-motion": "^12.35.2",
    "helmet": "^8.2.0",
    "lucide-react": "^0.577.0",
    "react": "19.2.3",
    "react-countup": "^6.5.3",
    "react-dom": "19.2.3",
    "react-google-charts": "^5.2.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.9.4",
    "recharts": "^2.12.7",
    "stripe": "^22.2.2",
    "three": "^0.184.0",
    "tsx": "^4.22.4",
    "viem": "^2.52.2",
    "wagmi": "^2.19.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.46.0",
    "vite": "^6.4.1"
  }
}
