# MOR sub-agent environment (OpenClaw gateway process)
# Copy to integrations/openclaw/subagents.env and adjust paths.

MOR_API_BASE=http://localhost:3001/api
MOR_DASHBOARD_URL=http://localhost:5173
MOR_REPO={{REPO_ROOT}}

# OpenClaw state for this repo (set by npm run openclaw:gateway)
# OPENCLAW_CONFIG_PATH=integrations/openclaw/openclaw.json
# OPENCLAW_STATE_DIR=integrations/openclaw/state

# Optional: Supabase JWT for protected MOR API routes
# MOR_AGENT_ACCESS_TOKEN=

# Slack workflow channels (channel IDs — C…)
# SLACK_CHANNEL_MOR_AGENTS=
# SLACK_CHANNEL_MOR_AUDIT=
# SLACK_CHANNEL_MOR_GITHUB_EVENTS=
# SLACK_CHANNEL_MOR_SUGGESTION=
# SLACK_CHANNEL_MOR_CODEFIX=

# GitHub webhook integration
# GITHUB_WEBHOOK_SECRET=
# GITHUB_TOKEN=
# GITHUB_AUTO_REVIEW_CODE=true
# GITHUB_AUTO_AUDIT_PR=true
# GITHUB_AUTO_SUGGESTION=false
# GITHUB_AUTO_SUGGESTION_ISSUES=true
# GITHUB_AUTO_AGENTS_ISSUES=true
# GITHUB_AUTO_CODEFIX=false
